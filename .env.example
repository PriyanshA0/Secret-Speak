# SecretSpeak environment template
# Copy this file to .env.local and fill in real values.
# PowerShell: Copy-Item .env.example .env.local

# -----------------------------------------------
# Clerk (required)
# -----------------------------------------------
# Get these from Clerk Dashboard -> API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_SECRET_KEY=sk_test_REPLACE_ME

# Optional Clerk route overrides (defaults shown)
CLERK_SIGN_IN_URL=/sign-in
CLERK_SIGN_UP_URL=/sign-up
CLERK_AFTER_SIGN_IN_URL=/
CLERK_AFTER_SIGN_UP_URL=/onboarding

# -----------------------------------------------
# MongoDB (required)
# -----------------------------------------------
# Atlas example:
# mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://REPLACE_ME

# Backward-compatible alternative key (optional)
# MONGO_CONNECTION_STRING=mongodb+srv://REPLACE_ME

# Optional database name (defaults to secretspeak)
MONGODB_DB=secretspeak

# -----------------------------------------------
# App
# -----------------------------------------------
# Public app URL used for redirects/canonical links
NEXT_PUBLIC_APP_URL=http://localhost:3000
